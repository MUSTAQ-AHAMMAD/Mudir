# =============================================================================
# .env.production — production environment template for Mudir / ORCHESTRA.
#
# Copy to `.env` on the production server and fill in real values:
#   cp .env.production .env
#
# NEVER commit a populated `.env` (it is git-ignored). Keep real secrets in a
# secrets manager / the host's protected environment, not in source control.
# =============================================================================

# ---- Runtime ----------------------------------------------------------------
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
# Public HTTPS URL of the deployment (used to verify webhook signatures).
PUBLIC_URL=https://example.com

# ---- Frontend build (public, non-secret; inlined by Vite at build time) -----
VITE_API_URL=/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ---- PostgreSQL (self-hosted, Supabase-compatible) --------------------------
POSTGRES_USER=mudir
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=mudir
# Full connection string used by the backend (points at the compose service).
# Substitute your real POSTGRES_PASSWORD for <PASSWORD> below.
DATABASE_URL=postgresql://mudir:<PASSWORD>@postgres:5432/mudir

# ---- Supabase (managed option — leave blank if using local postgres) --------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ---- Self-hosted AI services (ORCHESTRA) ------------------------------------
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODELS=llama3:8b
WHISPER_URL=http://whisper:9000
WHISPER_MODEL=medium
CHROMA_HOST=chromadb
CHROMA_PORT=8000
# Local model cache path inside the containers.
MODEL_PATH=/root/.ollama

# ---- WATI (WhatsApp Business API) -------------------------------------------
WATI_API_KEY=your_wati_api_key
WATI_API_ENDPOINT=https://live-server.wati.io
WATI_WEBHOOK_SECRET=your_wati_webhook_secret

# ---- Twilio (alternative WhatsApp transport) --------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_VALIDATE_SIGNATURE=true

# ---- OpenAI (optional cloud fallback; unused in fully self-hosted mode) ------
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1

# ---- Business rules ---------------------------------------------------------
# JS getDay() indices: 0=Sun … 5=Fri, 6=Sat. Saudi weekend = Fri,Sat.
WEEKEND_DAYS=5,6
TIMEZONE=Asia/Riyadh
ESCALATE_AFTER_DAYS=2
DEFAULT_TEAM_COUNT=3

# ---- Rate limiting (public webhook) -----------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# ---- Feature flags ----------------------------------------------------------
FEATURE_VOICE_NOTES=true
FEATURE_SELF_HOSTED_AI=true
FEATURE_ANALYTICS=true

# ---- Monitoring / alerting --------------------------------------------------
# Optional Slack-compatible webhook for deploy/monitor notifications.
NOTIFY_WEBHOOK=
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password
