# =============================================================================
# .env.staging — staging environment template for Mudir / ORCHESTRA.
#
# Mirrors .env.production but points at test/sandbox resources and uses more
# verbose logging. Copy to `.env` on the staging server:
#   cp .env.staging .env
#
# NEVER commit a populated `.env`.
# =============================================================================

# ---- Runtime ----------------------------------------------------------------
NODE_ENV=production
PORT=3000
LOG_LEVEL=debug
PUBLIC_URL=https://staging.example.com

# ---- Frontend build (public, non-secret) ------------------------------------
VITE_API_URL=/api
VITE_SUPABASE_URL=https://your-staging-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_staging_supabase_anon_key

# ---- PostgreSQL -------------------------------------------------------------
POSTGRES_USER=mudir
POSTGRES_PASSWORD=change_me_staging_password
POSTGRES_DB=mudir_staging
DATABASE_URL=postgresql://mudir:<PASSWORD>@postgres:5432/mudir_staging

# ---- Supabase (managed option) ----------------------------------------------
SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_SERVICE_KEY=your_staging_supabase_service_role_key

# ---- Self-hosted AI services (ORCHESTRA) ------------------------------------
OLLAMA_HOST=http://ollama:11434
# Lighter model in staging to keep resource usage low.
OLLAMA_MODELS=phi3:mini
WHISPER_URL=http://whisper:9000
WHISPER_MODEL=base
CHROMA_HOST=chromadb
CHROMA_PORT=8000
MODEL_PATH=/root/.ollama

# ---- WATI (use test/sandbox credentials) ------------------------------------
WATI_API_KEY=your_staging_wati_api_key
WATI_API_ENDPOINT=https://live-server.wati.io
WATI_WEBHOOK_SECRET=your_staging_wati_webhook_secret

# ---- Twilio (sandbox) -------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_staging_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_VALIDATE_SIGNATURE=true

# ---- OpenAI (optional) ------------------------------------------------------
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1

# ---- Business rules ---------------------------------------------------------
WEEKEND_DAYS=5,6
TIMEZONE=Asia/Riyadh
ESCALATE_AFTER_DAYS=2
DEFAULT_TEAM_COUNT=3

# ---- Rate limiting ----------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ---- Feature flags (enable experimental features in staging) ----------------
FEATURE_VOICE_NOTES=true
FEATURE_SELF_HOSTED_AI=true
FEATURE_ANALYTICS=true

# ---- Monitoring / alerting --------------------------------------------------
NOTIFY_WEBHOOK=
GRAFANA_ADMIN_PASSWORD=change_me_staging_grafana_password
