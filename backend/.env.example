# -----------------------------------------------------------------------------
# Mudir backend — environment variable template.
# Copy to `.env` and fill in real values. NEVER commit the real .env file.
# -----------------------------------------------------------------------------

# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
# Public URL used to verify Twilio webhook signatures — must match the URL
# configured in the Twilio console exactly (scheme + host + path).
PUBLIC_URL=https://your-app.onrender.com

# Twilio (WhatsApp Business API)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Sandbox sender by default; swap for your approved WhatsApp sender in prod.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Set to false only for local testing without real Twilio signatures.
TWILIO_VALIDATE_SIGNATURE=true

# Supabase (PostgreSQL)
SUPABASE_URL=https://your-project.supabase.co
# Service-role key (server-side only — keep secret, bypasses RLS).
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# OpenAI + Whisper
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1

# Business rules
# JS getDay() indices: 0=Sun … 5=Fri, 6=Sat. Saudi weekend = Fri,Sat.
WEEKEND_DAYS=5,6
TIMEZONE=Asia/Riyadh
ESCALATE_AFTER_DAYS=2
DEFAULT_TEAM_COUNT=3

# Rate limiting (public webhook)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
