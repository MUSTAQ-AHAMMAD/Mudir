# -----------------------------------------------------------------------------
# Mudir frontend — environment variable template.
# Copy to `.env`. All VITE_* vars are exposed to the browser: never put secret
# server keys here (use only the Supabase ANON/public key).
# -----------------------------------------------------------------------------

# Supabase (enables auth + real-time). Leave blank to run in demo mode.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Backend REST API base URL. Empty = same-origin (dev server proxies /api).
VITE_API_URL=http://localhost:3000

# Optional: default WhatsApp test group id used by the WhatsApp settings page.
VITE_WHATSAPP_GROUP_ID=your_test_group
